# Host path to your data directory (market.csv, trades.json, config.json, etc.)
# This directory is bind-mounted into the containers. Create it and populate it
# following docs/setup.md before running Docker Compose. The repo ships with
# demo-data/ for local exploration; use ./data (gitignored) for your real data.
DATA_DIR=./data

# Port the web UI is exposed on
PORT=8000

# HTTP Basic Auth password (leave empty to disable auth). Username is ignored.
# Accepts plaintext or a scrypt hash (recommended).
# Generate a hash: make hash-password PASSWORD=yourpassword
AUTH_PASS=
